{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "Template output schema for ONE discovery run. Replace the rubric-dimension keys (techDomainExperience ... thoughtLeadership) with YOUR dimensions from Step 1. Capability dimensions use the level enum [strong, partial, none, unknown]; strength dimensions use [none, weak, medium, strong, unknown]. Add 'extra' string-array fields (e.g. cloudArchitecture.clouds) where you want a captured list. Drop currentlyAtExcludedEmployer if you set no exclude_employer. Add requested contact fields (email/phone/uri, nullable with the matching format) only when the user asked for contact-ready candidates, and list them in required. Keep mobility as-is: its dated tenure fields feed the likely-to-move score (see scoring-and-calibration.md). Keep additionalProperties:false and list every field in required so the agent cannot omit fields.",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidates"],
  "properties": {
    "candidates": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name", "currentTitle", "currentCompany", "location", "linkedinUrl",
          "currentlyAtExcludedEmployer", "yearsRelevantExperience",
          "techDomainExperience", "designConsultingExperience", "customerFacingPresales",
          "cloudArchitecture", "migrationModernization", "thoughtLeadership",
          "seniority", "overallFit", "mobility"
        ],
        "properties": {
          "name": { "type": "string" },
          "currentTitle": { "type": "string" },
          "currentCompany": { "type": "string" },
          "location": { "type": ["string", "null"] },
          "linkedinUrl": { "type": ["string", "null"] },
          "currentlyAtExcludedEmployer": { "type": "boolean" },
          "yearsRelevantExperience": { "type": ["number", "null"] },

          "techDomainExperience": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals"],
            "properties": {
              "level": { "type": "string", "enum": ["strong", "partial", "none", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          },
          "designConsultingExperience": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals"],
            "properties": {
              "level": { "type": "string", "enum": ["strong", "partial", "none", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          },
          "customerFacingPresales": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals"],
            "properties": {
              "level": { "type": "string", "enum": ["strong", "partial", "none", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          },
          "cloudArchitecture": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals", "clouds"],
            "properties": {
              "level": { "type": "string", "enum": ["strong", "partial", "none", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } },
              "clouds": { "type": "array", "items": { "type": "string" } }
            }
          },
          "migrationModernization": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals"],
            "properties": {
              "level": { "type": "string", "enum": ["none", "weak", "medium", "strong", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          },
          "thoughtLeadership": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals"],
            "properties": {
              "level": { "type": "string", "enum": ["none", "weak", "medium", "strong", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          },

          "seniority": {
            "type": "object", "additionalProperties": false, "required": ["level", "signals"],
            "properties": {
              "level": { "type": "string", "enum": ["ic_mid", "ic_senior", "ic_staff_principal", "manager", "director_plus", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          },
          "overallFit": {
            "type": "object", "additionalProperties": false, "required": ["tier", "confidence", "signalsUsed", "concerns"],
            "properties": {
              "tier": { "type": "string", "enum": ["exceptional", "strong", "moderate", "weak", "unknown"] },
              "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
              "signalsUsed": { "type": "array", "items": { "type": "string" } },
              "concerns": { "type": "array", "items": { "type": "string" } }
            }
          },
          "mobility": {
            "type": "object", "additionalProperties": false,
            "required": ["monthsInCurrentRole", "monthsAtCurrentCompany", "avgMonthsPerPriorRole", "seniorityVsRole", "signals"],
            "properties": {
              "monthsInCurrentRole": { "type": ["number", "null"] },
              "monthsAtCurrentCompany": { "type": ["number", "null"] },
              "avgMonthsPerPriorRole": { "type": ["number", "null"] },
              "seniorityVsRole": { "type": "string", "enum": ["step_up", "aligned", "step_down", "unknown"] },
              "signals": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
